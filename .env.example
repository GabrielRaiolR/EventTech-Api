# Copie para .env (ou configure no IntelliJ / systemd na EC2) e preencha os valores.
# O arquivo .env não deve ser commitado (está no .gitignore).

# PostgreSQL (local ou RDS)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/eventostec
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=

# S3 — nome do bucket de imagens
AWS_S3_BUCKET=seu-bucket-aqui

# Região da conta AWS (opcional; default no application.properties é us-east-1)
# AWS_REGION=us-east-1

# Credenciais AWS (local / EC2 com usuário IAM)
# Na EC2 com IAM Role anexada à instância, estas variáveis costumam ser desnecessárias.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Docker Compose (opcional) ---
# O compose lê este arquivo automaticamente para substituir variáveis em docker-compose.yml.
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=eventostec
# AWS_S3_BUCKET=local-dev-bucket
